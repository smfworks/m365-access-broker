# OpenClaw M365 Access Broker configuration
# Copy to .env and fill in. With no real credentials the broker runs in DRY_RUN mode.

# Set to "false" to call real Microsoft Graph. Defaults to true (mock Graph, no network).
BROKER_DRY_RUN=true

# MSAL / Entra app registration (single-tenant, delegated auth recommended)
MS_TENANT_ID=
MS_CLIENT_ID=
# Authorization Code + PKCE does not require a secret for public clients.
MS_CLIENT_SECRET=
MS_REDIRECT_URI=http://localhost:3000/auth/callback

# Local broker HTTP server
BROKER_PORT=8787
# Agent credential (x-broker-key) for read/draft/execute calls.
# Host-UI credential (x-approver-key) for minting approvals — keep separate so
# the agent cannot grant its own approval. If either is empty the server
# generates an ephemeral key at startup and prints it (no "no auth" mode).
BROKER_KEY=
BROKER_APPROVER_KEY=

# Audit log path (JSON lines). Defaults to ./audit.log
BROKER_AUDIT_LOG=audit.log
